# ─────────────────────────────────────────────────────────────────────────────
# SALIN FILE INI KE .env.local UNTUK DEV LOKAL
# DI VERCEL: Settings → Environment Variables
# JANGAN PERNAH COMMIT FILE .env / .env.local KE GIT
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Dapatkan dari: Firebase Console → Project Settings → Service Accounts
# → Generate new private key → download JSON
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Salin private_key dari JSON (termasuk -----BEGIN PRIVATE KEY-----)
# Di .env.local: gunakan tanda kutip ganda dan \n literal
# Di Vercel Dashboard: paste langsung, Vercel otomatis handle newline
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXX\n-----END PRIVATE KEY-----\n"

# ── Gmail pengirim OTP ────────────────────────────────────────────────────────
# Gunakan Gmail App Password (bukan password biasa)
# Aktifkan di: myaccount.google.com → Security → 2-Step → App Passwords
GMAIL_USER=setoreemail@gmail.com
GMAIL_APP_PASS=xxxx xxxx xxxx xxxx

# ── Secret untuk session cookie ───────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=ganti_dengan_string_acak_panjang_minimal_32_karakter

# ── Secret untuk admin API routes ────────────────────────────────────────────
ADMIN_SECRET=ganti_dengan_secret_admin_yang_kuat

# ── External API (setorangmail) ───────────────────────────────────────────────
EXTERNAL_API_KEY=sgp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── (Frontend) Base URL API ───────────────────────────────────────────────────
VITE_API_BASE_URL=/api
